{
  "manifest_version": 3,
  "name": "Gmail Pic Minimizer",
  "version": "1.0.4",
  "description": "Bilder direkt beim Anhängen in Gmail komprimieren",
  "permissions": ["storage", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://mail.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page_script.js"],
      "matches": ["https://mail.google.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Gmail Pic Minimizer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
